df_join





df_reduzido = df[ ["zHD", "RA", "DEC", "MU_SH0ES", "MU_SH0ES_ERR_DIAG"]].rename(columns={"MU_SH0ES": "mu","MU_SH0ES_ERR_DIAG": "mu_err"})


df_reduzido








df[df["CID"].duplicated(keep=False)]


df["CID"].drop_duplicates()


df_unique = (
    df
    .drop_duplicates(subset="CID")
    .reset_index(drop=True)
)


df_unique





df_unique[df_unique["CID"].str.contains("2017cfd", na=False)]









df_base = df_reduzido.copy()
n_extra = 1800 - len(df_base)
# cria novas linhas totalmente NaN com as mesmas colunas
df_nan = pd.DataFrame(
    np.nan,
    index=range(n_extra),
    columns=df_base.columns
)

# junta os dois
df_final = pd.concat([df_base, df_nan], ignore_index=True)
df_final = df_final.sample(frac=1, random_state=42).reset_index(drop=True)


df_final





df_final.isna().sum()








df_final.dropna()


print("Antes:", len(df_final))
print("Depois dropna:", len(df_final.dropna()))


df_reduzido=df_final.dropna()


df_reduzido.isna().sum()





df_reduzido.sort_index(axis='columns')





df_reduzido.sort_values(by="zHD", ascending=False)





df_reduzido.sort_values(by="zHD", ascending=True)





df_reduzido['zHD'].hist(bins=20)

plt.axvline(df_reduzido['zHD'].mean(), color='red', linestyle='--', label='Média')
plt.axvline(df_reduzido['zHD'].median(), color='yellow', linestyle='-.', label='Mediana')
plt.axvline(df_reduzido['zHD'].max(), color='black', linestyle=':', label='Máximo')

plt.legend(loc=1)
plt.show()





mean = df_reduzido["zHD"].mean()
variance = df_reduzido["zHD"].var()
std = df_reduzido["zHD"].std()
skew = df_reduzido["zHD"].skew()
kurt = df_reduzido["zHD"].kurt()

print("Média:", mean)
print("Variância:", variance)
print("Desvio padrão:", std)
print("Skewness:", skew)
print("Kurtosis:", kurt)








